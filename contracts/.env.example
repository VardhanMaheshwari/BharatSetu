# Deployer wallet (must have Amoy MATIC + Sepolia ETH)
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Relayer wallet address (backend hot wallet that calls mintOnProof)
RELAYER_ADDRESS=0xYOUR_RELAYER_ADDRESS

# RPC endpoints (get from Alchemy / Infura / QuickNode)
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Block explorer API keys (for contract verification)
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
